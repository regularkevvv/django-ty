from typing import Any, Generic, TypeVar

_T = TypeVar("_T")
_Row = TypeVar("_Row")


class QuerySet(Generic[_T, _Row]):
    def all(self) -> QuerySet[_T, _Row]: ...
    def filter(self, *args: Any, **kwargs: Any) -> QuerySet[_T, _Row]: ...
    def exclude(self, *args: Any, **kwargs: Any) -> QuerySet[_T, _Row]: ...
    def complex_filter(self, filter_obj: Any) -> QuerySet[_T, _Row]: ...
    def get(self, *args: Any, **kwargs: Any) -> _Row: ...
    def create(self, **kwargs: Any) -> _T: ...
    def get_or_create(self, defaults: dict[str, Any] | None = None, **kwargs: Any) -> tuple[_T, bool]: ...
    def update_or_create(self, defaults: dict[str, Any] | None = None, create_defaults: dict[str, Any] | None = None, **kwargs: Any) -> tuple[_T, bool]: ...
    def first(self) -> _Row | None: ...
    def last(self) -> _Row | None: ...
    def earliest(self, *fields: str) -> _Row: ...
    def latest(self, *fields: str) -> _Row: ...
    def count(self) -> int: ...
    def exists(self) -> bool: ...
    def values(self, *fields: str, **expressions: Any) -> QuerySet[_T, dict[str, object]]: ...
    def values_list(self, *fields: str, flat: bool = False, named: bool = False) -> QuerySet[_T, object]: ...
    def annotate(self, *args: Any, **kwargs: Any) -> QuerySet[_T, _Row]: ...
    def alias(self, *args: Any, **kwargs: Any) -> QuerySet[_T, _Row]: ...
    def order_by(self, *field_names: str) -> QuerySet[_T, _Row]: ...
    def distinct(self, *field_names: str) -> QuerySet[_T, _Row]: ...
    def none(self) -> QuerySet[_T, _Row]: ...
    def only(self, *fields: str) -> QuerySet[_T, _Row]: ...
    def defer(self, *fields: str) -> QuerySet[_T, _Row]: ...
    def select_related(self, *fields: str | None) -> QuerySet[_T, _Row]: ...
    def prefetch_related(self, *lookups: str) -> QuerySet[_T, _Row]: ...
    def select_for_update(self, **kwargs: Any) -> QuerySet[_T, _Row]: ...
    def reverse(self) -> QuerySet[_T, _Row]: ...
    def using(self, alias: str | None) -> QuerySet[_T, _Row]: ...
    def union(self, *other_qs: QuerySet[_T, Any], all: bool = False) -> QuerySet[_T, _Row]: ...
    def intersection(self, *other_qs: QuerySet[_T, Any]) -> QuerySet[_T, _Row]: ...
    def difference(self, *other_qs: QuerySet[_T, Any]) -> QuerySet[_T, _Row]: ...
    async def aget(self, *args: Any, **kwargs: Any) -> _Row: ...
    async def acreate(self, **kwargs: Any) -> _T: ...
    async def aget_or_create(self, defaults: dict[str, Any] | None = None, **kwargs: Any) -> tuple[_T, bool]: ...
    async def aupdate_or_create(self, defaults: dict[str, Any] | None = None, create_defaults: dict[str, Any] | None = None, **kwargs: Any) -> tuple[_T, bool]: ...
    async def afirst(self) -> _Row | None: ...
    async def alast(self) -> _Row | None: ...
    async def acount(self) -> int: ...
    async def aexists(self) -> bool: ...


class Prefetch: ...


def prefetch_related_objects(model_instances: Any, *related_lookups: str) -> None: ...
async def aprefetch_related_objects(model_instances: Any, *related_lookups: str) -> None: ...
